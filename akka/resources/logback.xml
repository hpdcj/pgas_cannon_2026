<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- This is a development logging configuration that logs to standard out, for an example of a production
        logging config, see the Akka docs: https://doc.akka.io/docs/akka/ciurrent/typed/logging.html#logback -->
    <appender name="STDOUT" target="System.out" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
<!--            <pattern>[%date{ISO8601}] [%level] [%logger] [%marker] [%thread] - %msg%n</pattern>-->
            <pattern>%msg%n</pattern>
<!--            <pattern>[%thread] - %msg%n</pattern>-->
        </encoder>
    </appender>

    <appender name="ASYNC" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>8192</queueSize>
        <neverBlock>true</neverBlock>
        <appender-ref ref="STDOUT" />
    </appender>

    <logger name="akka" level="ERROR"/>
    <logger name="akka.actor" level="ERROR"/>
    <logger name="akka.remote" level="ERROR"/>
    <logger name="akka.cluster" level="ERROR"/>
    <logger name="akka.stream" level="ERROR"/>
    <logger name="akka.cluster.ClusterJmx" level="OFF"/>
    <logger name="akka.stream.impl.io.StreamTcpException" level="OFF"/>

    <root level="INFO">
        <appender-ref ref="ASYNC"/>
    </root>
</configuration>
